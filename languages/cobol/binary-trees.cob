>>SOURCE FORMAT FREE
*> binary-trees: allocation + GC-churn benchmark. Faithful port of
*> languages/c/binary-trees.c. Real heap nodes: a 01 NODE BASED group with two
*> USAGE POINTER child fields, ALLOCATE per node, SET ADDRESS OF NODE TO ptr to
*> dereference (modern COBOL dynamic allocation, NOT a flat OCCURS array). Build,
*> check and destroy are RECURSIVE contained programs with LOCAL-STORAGE, porting
*> the C recursion directly. Output: line 1 = the node-count checksum,
*> line 2 = binary-trees(n). Native ELF via cobc -> bit-exact under qemu+insn.
IDENTIFICATION DIVISION.
PROGRAM-ID. binary-trees.
DATA DIVISION.
WORKING-STORAGE SECTION.
01 WS-N            PIC S9(9)  COMP-5 VALUE 10.
01 WS-ARG          PIC X(16)         VALUE SPACES.
01 WS-MIN-DEPTH    PIC S9(9)  COMP-5 VALUE 4.
01 WS-MAX-DEPTH    PIC S9(9)  COMP-5.
01 WS-STRETCH      PIC S9(9)  COMP-5.
01 WS-DEPTH        PIC S9(9)  COMP-5.
01 WS-ITERATIONS   PIC S9(9)  COMP-5.
01 WS-SHIFT        PIC S9(9)  COMP-5.
01 WS-I            PIC S9(9)  COMP-5.
01 WS-TOTAL        PIC S9(18) COMP-5 VALUE 0.
01 WS-S            PIC S9(18) COMP-5.
01 WS-C            PIC S9(18) COMP-5.
01 WS-PTR          USAGE POINTER VALUE NULL.
01 WS-LONG-LIVED   USAGE POINTER VALUE NULL.
01 WS-T-PTR        USAGE POINTER VALUE NULL.
01 ED-CK           PIC -(18)9.
01 ED-N            PIC Z(8)9.
PROCEDURE DIVISION.
MAIN-PARA.
    DISPLAY 1 UPON ARGUMENT-NUMBER
    ACCEPT WS-ARG FROM ARGUMENT-VALUE
    IF WS-ARG NOT = SPACES
       COMPUTE WS-N = FUNCTION NUMVAL(WS-ARG)
    END-IF

    IF WS-MIN-DEPTH + 2 > WS-N
       COMPUTE WS-MAX-DEPTH = WS-MIN-DEPTH + 2
    ELSE
       MOVE WS-N TO WS-MAX-DEPTH
    END-IF
    COMPUTE WS-STRETCH = WS-MAX-DEPTH + 1

    CALL "make" USING WS-STRETCH WS-PTR
    CALL "check" USING WS-PTR WS-C
    ADD WS-C TO WS-TOTAL
    CALL "destroy" USING WS-PTR

    *> long-lived tree (built now, checked at the end)
    MOVE NULL TO WS-PTR
    CALL "make" USING WS-MAX-DEPTH WS-PTR

    MOVE WS-PTR TO WS-LONG-LIVED

    MOVE WS-MIN-DEPTH TO WS-DEPTH
    PERFORM UNTIL WS-DEPTH > WS-MAX-DEPTH
       COMPUTE WS-SHIFT = WS-MAX-DEPTH - WS-DEPTH + WS-MIN-DEPTH
       COMPUTE WS-ITERATIONS = FUNCTION INTEGER(2 ** WS-SHIFT)
       MOVE 0 TO WS-S
       PERFORM VARYING WS-I FROM 0 BY 1 UNTIL WS-I >= WS-ITERATIONS
          MOVE NULL TO WS-T-PTR
          CALL "make" USING WS-DEPTH WS-T-PTR
          CALL "check" USING WS-T-PTR WS-C
          ADD WS-C TO WS-S
          CALL "destroy" USING WS-T-PTR
       END-PERFORM
       ADD WS-S TO WS-TOTAL
       ADD 2 TO WS-DEPTH
    END-PERFORM

    CALL "check" USING WS-LONG-LIVED WS-C
    ADD WS-C TO WS-TOTAL
    CALL "destroy" USING WS-LONG-LIVED

    MOVE WS-TOTAL TO ED-CK
    MOVE WS-N     TO ED-N
    DISPLAY FUNCTION TRIM(ED-CK)
    DISPLAY "binary-trees(" FUNCTION TRIM(ED-N) ")"
    STOP RUN.
END PROGRAM binary-trees.

*> --- recursive node allocation ---
IDENTIFICATION DIVISION.
PROGRAM-ID. make IS RECURSIVE.
DATA DIVISION.
WORKING-STORAGE SECTION.
01 NODE BASED.
   05 NODE-LEFT   USAGE POINTER.
   05 NODE-RIGHT  USAGE POINTER.
LOCAL-STORAGE SECTION.
01 LS-NEW-PTR     USAGE POINTER.
01 LS-CHILD-DEPTH PIC S9(9) COMP-5.
LINKAGE SECTION.
01 LK-DEPTH       PIC S9(9) COMP-5.
01 LK-RESULT      USAGE POINTER.
PROCEDURE DIVISION USING LK-DEPTH LK-RESULT.
MAKE-PARA.
    ALLOCATE NODE RETURNING LS-NEW-PTR
    SET ADDRESS OF NODE TO LS-NEW-PTR
    IF LK-DEPTH = 0
       SET NODE-LEFT  TO NULL
       SET NODE-RIGHT TO NULL
    ELSE
       COMPUTE LS-CHILD-DEPTH = LK-DEPTH - 1
       CALL "make" USING LS-CHILD-DEPTH NODE-LEFT
       *> re-anchor NODE after the recursive call rebinds the BASED address
       SET ADDRESS OF NODE TO LS-NEW-PTR
       CALL "make" USING LS-CHILD-DEPTH NODE-RIGHT
       SET ADDRESS OF NODE TO LS-NEW-PTR
    END-IF
    SET LK-RESULT TO LS-NEW-PTR
    EXIT PROGRAM.
END PROGRAM make.

*> --- recursive node count ---
IDENTIFICATION DIVISION.
PROGRAM-ID. check IS RECURSIVE.
DATA DIVISION.
WORKING-STORAGE SECTION.
01 NODE BASED.
   05 NODE-LEFT   USAGE POINTER.
   05 NODE-RIGHT  USAGE POINTER.
LOCAL-STORAGE SECTION.
01 LS-LEFT-PTR    USAGE POINTER.
01 LS-RIGHT-PTR   USAGE POINTER.
01 LS-CL          PIC S9(18) COMP-5.
01 LS-CR          PIC S9(18) COMP-5.
LINKAGE SECTION.
01 LK-PTR         USAGE POINTER.
01 LK-RESULT      PIC S9(18) COMP-5.
PROCEDURE DIVISION USING LK-PTR LK-RESULT.
CHECK-PARA.
    SET ADDRESS OF NODE TO LK-PTR
    IF NODE-LEFT = NULL
       MOVE 1 TO LK-RESULT
    ELSE
       SET LS-LEFT-PTR  TO NODE-LEFT
       SET LS-RIGHT-PTR TO NODE-RIGHT
       CALL "check" USING LS-LEFT-PTR  LS-CL
       CALL "check" USING LS-RIGHT-PTR LS-CR
       COMPUTE LK-RESULT = 1 + LS-CL + LS-CR
    END-IF
    EXIT PROGRAM.
END PROGRAM check.

*> --- recursive free ---
IDENTIFICATION DIVISION.
PROGRAM-ID. destroy IS RECURSIVE.
DATA DIVISION.
WORKING-STORAGE SECTION.
01 NODE BASED.
   05 NODE-LEFT   USAGE POINTER.
   05 NODE-RIGHT  USAGE POINTER.
LOCAL-STORAGE SECTION.
01 LS-LEFT-PTR    USAGE POINTER.
01 LS-RIGHT-PTR   USAGE POINTER.
01 LS-SELF        USAGE POINTER.
LINKAGE SECTION.
01 LK-PTR         USAGE POINTER.
PROCEDURE DIVISION USING LK-PTR.
DESTROY-PARA.
    MOVE LK-PTR TO LS-SELF
    SET ADDRESS OF NODE TO LK-PTR
    IF NODE-LEFT NOT = NULL
       SET LS-LEFT-PTR  TO NODE-LEFT
       SET LS-RIGHT-PTR TO NODE-RIGHT
       CALL "destroy" USING LS-LEFT-PTR
       CALL "destroy" USING LS-RIGHT-PTR
    END-IF
    SET ADDRESS OF NODE TO LS-SELF
    FREE NODE
    EXIT PROGRAM.
END PROGRAM destroy.
